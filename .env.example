# ========================================
# Pulse — Environment Variables
# ========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ─── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=pulse_dev

# ─── AI API Keys ───────────────────────────────────────────────────────────────
# Obtain from:
#  - OpenAI:  https://platform.openai.com/api-keys
#  - Claude:  https://console.anthropic.com/settings/keys
#
# Leave empty if you don't have keys — the AI features will be disabled.
# The system tries OpenAI first, falls back to Claude automatically.
OPENAI_API_KEY=
CLAUDE_API_KEY=

# ─── AI Cost Management ────────────────────────────────────────────────────────
# Maximum number of articles to summarize per month.
# At $0.002/article (gpt-4o-mini), 500 articles ≈ $1/month.
AI_MONTHLY_ARTICLE_CAP=500

# ─── Frontend ──────────────────────────────────────────────────────────────────
# URL of the backend, as seen from the browser.
# For local dev: http://localhost:8080
# For production: https://api.yourdomain.com
VITE_API_URL=http://localhost:8080
